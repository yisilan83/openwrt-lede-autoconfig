config AdGuardHome 'AdGuardHome'
	option enabled '1'
	option httpport '3000'
	option redirect 'none'
	option binpath '/etc/adguardhome/AdGuardHome'
	option upxflag ''
	option configpath '/etc/adguardhome/adguardhome.yaml'
	option workdir '/etc/adguardhome'
	option logfile '/var/log/AdGuardHome.log'
	option verbose '0'
	option waitonboot '1'
